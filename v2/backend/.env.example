# ═══════════════════════════════════════════
# Skillovate V2 — Environment Configuration
# ═══════════════════════════════════════════

# --- Application ---
APP_NAME=Skillovate V2
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# --- Database ---
DATABASE_URL=postgresql+psycopg://skillovate:skillovate_secret@localhost:5432/skillovate_v2
ASYNC_DATABASE_URL=postgresql+asyncpg://skillovate:skillovate_secret@localhost:5432/skillovate_v2

# --- JWT ---
JWT_SECRET_KEY=change-this-to-a-random-64-char-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60

# --- Email (future) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@skillovate.com

# --- Super Admin Seed ---
SUPER_ADMIN_EMAIL=admin@skillovate.com
SUPER_ADMIN_PASSWORD=admin123
